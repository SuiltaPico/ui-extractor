**/target/
**/.dart_tool/
**/.packages
**/build/
# Legacy: .venv was only used for pip pnnx; portable pnnx is recommended instead
.venv/
**/*.rs.bk

# Manifest model packs (scripts/install_packs.ps1)
models/*/
# Legacy flat weights (removed)
models/*.onnx
models/*.ncnn.param
models/*.ncnn.bin

# ncnn prebuilt libs (see android/README.md)
third_party/
vendor/
android/jniLibs/

# MDI SVG/PNG/embeddings — generate in local-infer-core (see that repo's .gitignore)

# Regenerated by `ui-extractor cases`
tests/cases/*/pipeline/
tests/cases/*/timing.json
tests/cases/*/skeleton.html

# Local cargo overrides (scripts/build_android.ps1)
.cargo/config.local.toml

# Downloaded infer-core native libs (scripts/download_infer_core_release.ps1)
.infer-core-release*/

# Release packages (scripts/build_release_*.ps1)
dist/
